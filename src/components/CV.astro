---
import Icon from './Icon.astro';
import { site } from '../data/site';

// The CV is shown as page images. Mobile browsers refuse to render inline PDFs
// (<object>/<embed>), so images are the only display that works everywhere; the
// buttons above still serve the real PDF. Regenerate the images after updating
// public/cv.pdf with: npm run gen:cv
const cvPages = [1, 2, 3];
---

<section id="cv" class="section">
  <div class="container">
    <p class="eyebrow" data-num="06">CV</p>
    <h2 class="section-title reveal">Curriculum vitae</h2>

    <div class="cv-wrap">
      <div class="btn-row reveal">
        <a class="btn btn--primary" href={site.cvPath} download>
          <Icon name="download" size="1.05rem" /> Download CV (PDF)
        </a>
        <a class="btn btn--ghost" href={site.cvPath} target="_blank" rel="noopener">
          <Icon name="external" size="1.05rem" /> Open in new tab
        </a>
      </div>

      <div class="cv-frame reveal" tabindex="0" role="group" aria-label={`${site.name} — Curriculum Vitae, ${cvPages.length} pages`}>
        {
          cvPages.map((n) => (
            <img
              class="cv-page"
              src={`/cv-${n}.jpg`}
              width="1190"
              height="1683"
              alt={`${site.name} — CV, page ${n} of ${cvPages.length}`}
              loading="lazy"
              decoding="async"
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
