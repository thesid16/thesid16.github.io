---
import Icon from './Icon.astro';
import { profileLinks } from '../data/site';

interface Props {
  /** Show the handle/address text next to each icon. */
  showHandles?: boolean;
  class?: string;
}
const { showHandles = false, class: className } = Astro.props;
---

<ul class:list={['profiles', className]}>
  {
    profileLinks.map((link) => {
      const external = link.href.startsWith('http');
      return (
        <li>
          <a
            href={link.href}
            aria-label={link.label}
            {...(external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            <Icon name={link.icon} />
            {showHandles ? <span>{link.handle}</span> : <span class="sr-only">{link.label}</span>}
          </a>
        </li>
      );
    })
  }
</ul>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
