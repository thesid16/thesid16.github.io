---
/**
 * Inline SVG icon set. All icons inherit `currentColor`, so they theme for free.
 * Usage: <Icon name="github" /> — size via the `size` prop or CSS on the svg.
 */
interface Props {
  name: string;
  size?: number | string;
  title?: string;
  class?: string;
}
const { name, size, title, class: className } = Astro.props;

type IconDef = { body: string; fill?: boolean; viewBox?: string };

const icons: Record<string, IconDef> = {
